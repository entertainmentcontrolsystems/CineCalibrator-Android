<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ── Header ───────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SCAN RESULTS"
            android:textColor="@color/accent_cyan"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvFixtureName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/tvManufacturer"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"/>
                    <TextView
                        android:id="@+id/tvDiodeCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvAvgCCT"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- New Scan button top-right -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNewScan"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="New Scan"
                android:textSize="13sp"
                app:cornerRadius="10dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/accent_cyan"
                android:textColor="@color/accent_cyan"/>
        </LinearLayout>

        <!-- ── Camera Calibration ─────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CAMERA CALIBRATION"
            android:textColor="@color/section_label"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvCalibrationStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Not calibrated — results are raw camera values"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvGamutProfileSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_hint"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCalibrateCamera"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="Calibrate Camera…"
                        android:textSize="13sp"
                        app:cornerRadius="8dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClearCalibration"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:text="Clear"
                        android:textSize="13sp"
                        android:visibility="gone"
                        app:cornerRadius="8dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="@color/error_red"
                        android:textColor="@color/error_red"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── CIE Diagram ─────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CIE 1931 CHROMATICITY"
            android:textColor="@color/section_label"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">
            <com.cinecalibrator.ui.CIEChartView
                android:id="@+id/cieChartView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"/>
        </androidx.cardview.widget.CardView>

        <!-- ── Gamut Coverage ──────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GAMUT COVERAGE"
            android:textColor="@color/section_label"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView android:id="@+id/tvRec709" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="Rec.709: —"
                    android:textColor="@color/gamut_709" android:textSize="13sp" android:layout_marginBottom="6dp"/>
                <ProgressBar android:id="@+id/progressRec709" style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent" android:layout_height="10dp"
                    android:progressTint="@color/gamut_709" android:progressBackgroundTint="#222222"
                    android:max="100" android:layout_marginBottom="14dp"/>

                <TextView android:id="@+id/tvRec2020" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="Rec.2020: —"
                    android:textColor="@color/gamut_2020" android:textSize="13sp" android:layout_marginBottom="6dp"/>
                <ProgressBar android:id="@+id/progressRec2020" style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent" android:layout_height="10dp"
                    android:progressTint="@color/gamut_2020" android:progressBackgroundTint="#222222"
                    android:max="100" android:layout_marginBottom="14dp"/>

                <TextView android:id="@+id/tvAcesAP1" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="ACES AP1: —"
                    android:textColor="@color/gamut_aces" android:textSize="13sp" android:layout_marginBottom="6dp"/>
                <ProgressBar android:id="@+id/progressAcesAP1" style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent" android:layout_height="10dp"
                    android:progressTint="@color/gamut_aces" android:progressBackgroundTint="#222222"
                    android:max="100"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Per-Diode Table ────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PER-DIODE MEASUREMENTS"
            android:textColor="@color/section_label"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDiodes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="20dp"/>

        <!-- ── Spectrometer Detail (C-800 only) ──────────────── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardSpectrometerDetail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SPECTROMETER DETAIL  (Sekonic C-800)"
                    android:textColor="@color/accent_cyan"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="12dp"/>

                <!-- Source indicator -->
                <TextView
                    android:id="@+id/tvSpectrometerSource"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Measured by Sekonic C-800 spectrometer"
                    android:textColor="@color/success_green"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="12dp"/>

                <!-- Broadcast quality metrics row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="TM-30 Rf" android:textColor="@color/text_hint" android:textSize="10sp"/>
                        <TextView android:id="@+id/tvTm30Rf" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textColor="@color/text_primary" android:textSize="20sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="TM-30 Rg" android:textColor="@color/text_hint" android:textSize="10sp"/>
                        <TextView android:id="@+id/tvTm30Rg" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textColor="@color/text_primary" android:textSize="20sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="TLCI" android:textColor="@color/text_hint" android:textSize="10sp"/>
                        <TextView android:id="@+id/tvTlci" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textColor="@color/text_primary" android:textSize="20sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="SSI-D" android:textColor="@color/text_hint" android:textSize="10sp"/>
                        <TextView android:id="@+id/tvSsiD" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textColor="@color/text_primary" android:textSize="20sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="SSI-T" android:textColor="@color/text_hint" android:textSize="10sp"/>
                        <TextView android:id="@+id/tvSsiT" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textColor="@color/text_primary" android:textSize="20sp" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Lux / fc / Dominant WL -->
                <TextView
                    android:id="@+id/tvSpectroLux"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="8dp"/>

                <!-- CRI R1-R15 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CRI R1 – R15"
                    android:textColor="@color/text_hint"
                    android:textSize="10sp"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvCriRValues"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="12dp"/>

                <!-- SPD diagram -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SPECTRAL POWER DISTRIBUTION  (380–780 nm, 5 nm steps)"
                    android:textColor="@color/text_hint"
                    android:textSize="10sp"
                    android:layout_marginBottom="6dp"/>

                <com.cinecalibrator.ui.SPDView
                    android:id="@+id/spdView"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Color Volume ──────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="COLOR VOLUME  (CIE xyY)"
            android:textColor="@color/section_label"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Each emitter shown as a pillar: base = CIE xy chromaticity, height = relative luminance (Y). Scatter cloud = all measured blend combinations."
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:lineSpacingExtra="2dp"
                    android:layout_marginBottom="8dp"/>

                <com.cinecalibrator.ui.ColorVolumeXYYView
                    android:id="@+id/colorVolumeXYYView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvColorVolumeStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Color volume scan not yet run — enable in Setup scan options"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"
                    android:layout_marginBottom="10dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnExportColorVolume"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Export Color Volume CSV"
                    android:textSize="14sp"
                    android:enabled="false"
                    app:cornerRadius="8dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="@color/gamut_2020"
                    android:textColor="@color/gamut_2020"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── LUT Section ────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LUT GENERATION"
            android:textColor="@color/section_label"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Target Color Space"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="6dp"/>

                <Spinner
                    android:id="@+id/spinnerLUTTarget"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/spinner_bg"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvLUTStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="LUT will be generated after scan"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Planckian Sweep ──────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardPlanckianSweep"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="PLANCKIAN SWEEP"
                    android:textColor="@color/accent_cyan"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Closed-loop calibration along the black body curve — 84 points from 1700K to 10000K at every 100K interval. The C-800 measures each blend and adjusts DMX iteratively to hit the target CCT. Takes ~25–40 minutes. The .pct.json output replaces EOS's linear solver for all warm-to-cool mixes."
                    android:textColor="@color/text_hint"
                    android:textSize="11sp"
                    android:lineSpacingExtra="2dp"
                    android:layout_marginBottom="12dp"/>

                <!-- Progress display (shown during sweep) -->
                <TextView
                    android:id="@+id/tvSweepProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp"/>

                <ProgressBar
                    android:id="@+id/progressSweep"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:max="100"
                    android:progress="0"
                    android:visibility="gone"
                    android:layout_marginBottom="12dp"/>

                <!-- Table summary (shown after sweep) -->
                <TextView
                    android:id="@+id/tvSweepResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:visibility="gone"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStartSweep"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="8dp"
                    android:text="▶  Run Planckian Sweep  (1700–10000K)"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:cornerRadius="10dp"
                    app:backgroundTint="@color/accent_cyan"
                    android:textColor="@color/bg_dark"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnExportPCT"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="⬇  Export .pct.json"
                    android:textSize="13sp"
                    android:enabled="false"
                    app:cornerRadius="10dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="@color/accent_cyan"
                    android:textColor="@color/accent_cyan"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Export Buttons ─────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EXPORT"
            android:textColor="@color/section_label"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExportPDF"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="📄 PDF"
                android:textSize="13sp"
                app:cornerRadius="10dp"
                app:backgroundTint="#1A3A5C"
                app:strokeColor="#3399FF"
                app:strokeWidth="1dp"
                android:textColor="@color/gamut_709"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExportCSV"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="📊 CSV"
                android:textSize="13sp"
                app:cornerRadius="10dp"
                app:backgroundTint="#1A3A2A"
                app:strokeColor="#33FF99"
                app:strokeWidth="1dp"
                android:textColor="@color/gamut_2020"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExportLUT"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🎨  Export LUT (.cube)"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/accent_cyan"
            android:textColor="@color/bg_dark"
            android:enabled="false"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExportGDTF"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="📦  Export Calibrated GDTF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"
            app:cornerRadius="12dp"
            app:backgroundTint="#2A1A40"
            app:strokeColor="#8855FF"
            app:strokeWidth="1dp"
            android:textColor="#BB88FF"/>

    </LinearLayout>
</ScrollView>
