<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Full-screen camera preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/cameraPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:scaleType="fillCenter"/>

    <!-- Darkened top bar -->
    <View
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#CC000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Back button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_margin="16dp"
        android:text="← Setup"
        android:textSize="13sp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        app:strokeColor="#44FFFFFF"
        android:textColor="@color/text_primary"
        app:cornerRadius="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Camera ready indicator -->
    <TextView
        android:id="@+id/ivCameraReady"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⏳ Starting camera…"
        android:textColor="@color/text_hint"
        android:textSize="13sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="20dp"/>

    <!-- Setup tip banner -->
    <androidx.cardview.widget.CardView
        android:id="@+id/tvSetupTip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="80dp"
        app:cardBackgroundColor="#CC1A2530"
        app:cardCornerRadius="10dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📐"
                android:textSize="20sp"
                android:layout_marginEnd="10dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tripod Setup Required"
                    android:textColor="@color/accent_cyan"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mount phone on tripod. Place the light source within the crosshair. Recommended distance: 1–3 m. Ensure the light fills less than 50% of frame."
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:lineSpacingExtra="2dp"/>
                <TextView
                    android:id="@+id/tvScanSummary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent_orange"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp"
                    android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ROI Crosshair overlay (custom view drawn over camera) -->
    <com.cinecalibrator.ui.ROIOverlayView
        android:id="@+id/roiOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Clipping warning -->
    <androidx.cardview.widget.CardView
        android:id="@+id/clippingWarning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        app:cardBackgroundColor="#CC8B0000"
        app:cardCornerRadius="10dp"
        app:cardElevation="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="160dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠  Sensor clipping detected — reduce light intensity or increase distance"
            android:textColor="#FFFF99"
            android:textSize="12sp"
            android:padding="12dp"/>
    </androidx.cardview.widget.CardView>

    <!-- Progress card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/progressCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="#EE0D1117"
        app:cardCornerRadius="14dp"
        app:cardElevation="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/btnStartScan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvProgressLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Preparing…"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvDiodeStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent_cyan"
                    android:textSize="12sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressBar"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:progressTint="@color/accent_cyan"
                android:progressBackgroundTint="#333333"
                android:max="100"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvDiodeResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:visibility="gone"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Measurement source banner + C-800 test -->
    <LinearLayout
        android:id="@+id/layoutSourceBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/btnStartScan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Source indicator row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1A2030"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:layout_marginBottom="6dp">

            <ImageView
                android:id="@+id/ivScanSourceIcon"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_dot_red"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvScanSource"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Measurement source: Phone camera"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTestMeter"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Test C-800"
                android:textSize="11sp"
                android:visibility="gone"
                app:cornerRadius="6dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/accent_cyan"
                android:textColor="@color/accent_cyan"/>
        </LinearLayout>

        <!-- Test result box (shown after tapping Test C-800) -->
        <TextView
            android:id="@+id/tvTestResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A2030"
            android:padding="10dp"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:visibility="gone"
            android:layout_marginBottom="4dp"/>
    </LinearLayout>

    <!-- Start Scan button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStartScan"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="24dp"
        android:text="▶  Start Scan"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/bg_dark"
        app:backgroundTint="@color/accent_cyan"
        app:cornerRadius="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
