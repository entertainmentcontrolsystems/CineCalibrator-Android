<?xml version="1.0" encoding="utf-8"?>
<!--
    USB device filter for Sekonic C-800 / C-800-U spectrometer.
    Add to your AndroidManifest.xml activity intent-filter to auto-launch
    when the device is plugged in:

    <activity ...>
        <intent-filter>
            <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"/>
        </intent-filter>
        <meta-data
            android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
            android:resource="@xml/sekonic_usb_device_filter"/>
    </activity>
-->
<resources>
    <usb-device
        vendor-id="2625"
        product-id="28675" />
    <!--
        vendor-id  = 0x0A41 = 2625  (Sekonic Corporation)
        product-id = 0x7003 = 28675 (C-800 / C-800-U)
        Values must be decimal in this file.
    -->
</resources>
